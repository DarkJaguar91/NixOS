// Named workspaces so rules can target them; declaration order pins
// them to indices 1-3, keeping Mod+2 = web and Mod+3 = games like
// mango's tags
workspace "main"
workspace "web"
workspace "games"

// Window rules
window-rule {
    match app-id="^brave-browser$"
    open-on-workspace "web"
}

window-rule {
    match app-id="^steam$"
    match app-id="^steam_app_.*$"
    open-on-workspace "games"
}
